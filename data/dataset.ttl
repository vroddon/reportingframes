    nif:isString        "The Commission shall publish guidelines on good distribution practice. To this end, it shall consult the Committee for Medicinal Products for Human Use and the Pharmaceutical Committee established by Council Decision 75/320/EEC OJ L 147, 9.6.1975, p.�23." ;
    nif:beginIndex      0 ;
    nif:endIndex        254 ;
