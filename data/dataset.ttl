<https://frames.linkeddata.es/text/02013L0036-20150101/title_VII__chp_2__sec_IV__art_107__para_2#char=0,301>
    a                   nif:Context, nif:String ;
    nif:isString        "EBA shall annually report to the European Parliament and the Council on the degree of convergence of the application of this Chapter between Member States. In order to increase the degree of such convergence, EBA shall conduct peer reviews in accordance with Article 30 of Regulation (EU) No 1093/2010" ;
    nif:beginIndex      0 ;
